# /etc/gudocs/env 로 복사 후 실제 값으로 교체
# sudo install -m 600 -o ubuntu -g ubuntu env.example /etc/gudocs/env

DB_URL=jdbc:mysql://127.0.0.1:3306/gudocs
DB_USER=gudocs
DB_PASSWORD=CHANGE_ME

# 프론트 도메인 (콤마로 여러 개 가능)
CORS_ALLOWED_ORIGINS=https://gudocs-fe-8xxs.vercel.app

# 크로스 사이트 세션 쿠키 (HTTPS 필수)
COOKIE_SAME_SITE=none
COOKIE_SECURE=true